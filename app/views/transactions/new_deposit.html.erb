<div class="max-w-xl mx-auto py-10 px-4">

  <div class="bg-white border rounded-2xl p-8 shadow-sm">

    <h1 class="text-3xl font-bold mb-6">
      Deposit
    </h1>

    <%= form_with url: deposit_path, method: :post, local: true do |form| %>

      <div class="mb-6">

        <%= label_tag :amount,
          "Amount",
          class: "block mb-2 font-medium" %>

        <%= number_field_tag :amount,
          nil,
          step: 0.01,
          class: "w-full border rounded-xl px-4 py-3" %>

      </div>

      <%= form.submit "Deposit",
        class: "w-full bg-black text-white py-3 rounded-xl hover:bg-gray-800 cursor-pointer" %>

    <% end %>

  </div>

</div>
