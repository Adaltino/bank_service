<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-xl bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
    <div class="mb-6">
      <h1 class="text-2xl font-semibold text-gray-900">Cole o código PIX</h1>

      <p class="text-sm text-gray-500 mt-2">Insira o código “copia e cola” para continuar o pagamento.</p>
    </div>

    <%= form_with url: validate_pix_path, class: "space-y-6" do |f| %>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Código PIX</label>

        <%= f.text_area :pix_code,
            rows: 5,
            placeholder: "Cole aqui seu código PIX...",
            class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-800 placeholder-gray-400
                    focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 focus:outline-none transition resize-none" %>
      </div>

      <%= f.submit "Continuar",
          class: "w-full bg-green-600 hover:bg-green-700 active:scale-[0.99] transition
                 text-black font-medium py-3 rounded-xl shadow-sm" %>
    <% end %>
  </div>
</div>