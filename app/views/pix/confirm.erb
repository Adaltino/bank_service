<div class="max-w-md mx-auto mt-10 bg-white shadow-lg rounded-2xl p-6 border border-gray-100">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Confirmar pagamento</h1>

  <div class="space-y-4 text-gray-700">
    <div class="flex justify-between items-center">
      <span class="text-sm text-gray-500">Loja</span>
      <span class="font-medium text-gray-800"><%= @payment["merchant"] %></span>
    </div>

    <div class="flex justify-between items-center">
      <span class="text-sm text-gray-500">Valor</span>
      <span class="font-semibold text-green-600 text-lg"><%= number_to_currency(@payment["amount"]) %></span>
    </div>

    <div class="flex justify-between items-center">
      <span class="text-sm text-gray-500">Expira em</span>
      <span class="text-sm text-gray-800"><%= @payment["expires_at"] %></span>
    </div>
  </div>

  <div class="mt-8">
    <%= button_to pay_pix_path(pix_code: @pix_code), method: :post,
        class: "w-full bg-green-600 hover:bg-green-700 text-black font-semibold py-3 rounded-xl transition duration-200 shadow-md hover:shadow-lg" do %>
      Pagar PIX
    <% end %>
  </div>
</div>